# Client ID de PayPal (Sandbox por ahora) — se expone al cliente para cargar el SDK de los botones.
# El Client Secret ya NO va aquí: vive en SSM Parameter Store del backend (random-trips-backend-eu).
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# URL del backend serverless (output ApiUrl del stack RandomTrips-Api).
NEXT_PUBLIC_API_BASE=https://0wq87itlt6.execute-api.us-east-1.amazonaws.com

# Dominio de CloudFront del bucket de media (output CdnDomainName del stack RandomTrips-Media).
NEXT_PUBLIC_MEDIA_CDN_DOMAIN=dk90mrq00fpjw.cloudfront.net
